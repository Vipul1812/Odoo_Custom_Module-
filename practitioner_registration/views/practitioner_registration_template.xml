<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="registration_page_template" name="Practitioner Registration">
        <t t-call="website.layout">
            <div id="wrap" class="oe_structure oe_empty">
                <section class="s_title pt32 pb32">
                    <div class="container text-center">
                        <h1 class="display-4">HPCSA Practitioner Registration</h1>
                        <p class="lead">Please provide your professional details below.</p>
                    </div>
                </section>

                <div class="container pb64">
                    <form action="/registration/submit" method="post" enctype="multipart/form-data" class="container-fluid mt-3" id="practitioner_registration_form">
                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                        
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Full Name *</label>
                                <input type="text" class="form-control" name="name" required="1"/>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Email *</label>
                                <input type="email" class="form-control" name="email" required="1"/>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Phone Number</label>
                                <input type="tel" class="form-control" name="phone"/>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">HPCSA Student Reg Number</label>
                                <input type="text" class="form-control" name="registration_number"/>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Profession/Category</label>
                                <select name="profession_category_id" class="form-select">
                                    <option value="">Select...</option>
                                    <t t-foreach="professions" t-as="prof">
                                        <option t-att-value="prof.id"><t t-esc="prof.name"/></option>
                                    </t>
                                </select>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Board Type</label>
                                <select name="board_type_id" class="form-select">
                                    <option value="">Select...</option>
                                    <t t-foreach="boards" t-as="board">
                                        <option t-att-value="board.id"><t t-esc="board.name"/></option>
                                    </t>
                                </select>
                            </div>

                            <div class="col-md-12 mb-4 mt-2">
                                <div class="form-check form-check-inline">
                                    <input class="form-check-input" type="checkbox" name="rwpos_approval" id="rwpos"/>
                                    <label class="form-check-label" for="rwpos">RWOPS Approval</label>
                                </div>
                                <div class="form-check form-check-inline">
                                    <input class="form-check-input" type="checkbox" name="sessional_contract" id="sessional"/>
                                    <label class="form-check-label" for="sessional">Sessional Contract</label>
                                </div>
                            </div>

                            <div class="col-12 mb-4">
                                <h4 class="border-bottom pb-2">Licensure Details</h4>
                                
                                <div class="row align-items-end" id="licensure_input_row">
                                    <div class="col-md-5 mb-3">
                                        <label class="form-label fw-bold">Licensure Name</label>
                                        <input type="text" id="temp_lic_name" class="form-control" placeholder="e.g. Annual Practising Certificate"/>
                                    </div>
                                    <div class="col-md-5 mb-3">
                                        <label class="form-label fw-bold">Upload Document</label>
                                        <input type="file" id="temp_lic_file" class="form-control" accept="application/pdf,image/*"/>
                                    </div>
                                    <div class="col-md-2 mb-3">
                                        <button type="button" class="btn btn-secondary w-100" id="add_licensure_row">
                                            <i class="fa fa-plus me-1"/> Add
                                        </button>
                                    </div>
                                </div>

                                <table class="table table-sm mt-3 d-none" id="licensure_table">
                                    <thead>
                                        <tr class="table-light">
                                            <th>Name</th>
                                            <th>File</th>
                                            <th class="text-center">Action</th>
                                        </tr>
                                    </thead>
                                    <tbody id="licensure_tbody">
                                        </tbody>
                                </table>

                                <div id="hidden_files_container" style="display:none;"></div>
                            </div>

                            <div class="col-12 mb-4">
                                <h4 class="border-bottom pb-2">Qualifications</h4>
                                <table class="table table-sm" id="qualifications_table">
                                    <thead>
                                        <tr>
                                            <th>Degree/Title</th>
                                            <th>Year</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr>
                                            <td><input type="text" name="qual_name_1" class="form-control" placeholder="e.g. MBChB"/></td>
                                            <td><input type="text" name="qual_year_1" class="form-control" placeholder="2024"/></td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>

                        <div class="text-center">
                            <button type="submit" class="btn btn-primary btn-lg px-5">Submit Registration</button>
                        </div>
                    </form>
                </div>
            </div>
        </t>
    </template>
</odoo>