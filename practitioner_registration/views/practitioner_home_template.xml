<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="home_template" name="HPCSA Home Page">
        <t t-call="website.layout">
            <div id="wrap" class="hpcsa_custom_page">
                <!-- HERO SECTION -->
                <section class="position-relative text-white" style="min-height:600px; overflow:hidden;">
                    <!-- COLORED MENU BOXES -->
                    <div class="container" style="position:absolute; top:40px; left:0; right:0; z-index:20;">
                        <div class="row g-3">
                            <!-- 1 Professional Boards -->
                            <div class="col-lg-3 col-md-6 dropdown">
                                <div style="background:#d4b116;height:90px;border-radius:12px;display:flex;flex-direction:column;align-items:center;justify-content:center;font-size:18px;font-weight:600;cursor:pointer;"
                                    data-bs-toggle="dropdown"
                                    aria-expanded="false">
                                    <div>Professional Boards</div>
                                    <i class="fa fa-angle-down mt-2"></i>
                                </div>
                                <ul class="dropdown-menu shadow-lg border-0 p-4 mt-2"
                                    style="min-width:450px;border-radius:15px;z-index:9999;">
                                    <div class="row text-start text-dark fw-normal">
                                        <div class="col-6 mb-2">
                                            <a class="dropdown-item" href="#">
                                                <i class="fa fa-users text-primary me-2"></i> Board Overview
                                            </a>
                                        </div>
                                        <div class="col-6 mb-2">
                                            <a class="dropdown-item" href="#">
                                                <i class="fa fa-gavel text-primary me-2"></i> Legal Framework
                                            </a>
                                        </div>
                                        <div class="col-6">
                                            <a class="dropdown-item" href="#">
                                                <i class="fa fa-calendar text-primary me-2"></i> Meetings
                                            </a>
                                        </div>
                                        <div class="col-6">
                                            <a class="dropdown-item" href="#">
                                                <i class="fa fa-info-circle text-primary me-2"></i> Guidelines
                                            </a>
                                        </div>
                                    </div>
                                </ul>
                            </div>
                            <!-- 2 Registration -->
                            <div class="col-lg-3 col-md-6 dropdown">
                                <div style="background:#16a765;height:90px;border-radius:12px;display:flex;flex-direction:column;align-items:center;justify-content:center;font-size:18px;font-weight:600;cursor:pointer;"
                                    data-bs-toggle="dropdown"
                                    aria-expanded="false">
                                    <div>Registration</div>
                                    <i class="fa fa-angle-down mt-2"></i>
                                </div>
                                <ul class="dropdown-menu shadow-lg border-0 p-4 mt-2"
                                    style="min-width:550px;border-radius:15px;">
                                    <div class="row text-start text-dark fw-normal">
                                        <div class="col-6 mb-3">
                                            <a class="dropdown-item d-flex align-items-center" href="#">
                                                <i class="fa fa-search-plus text-primary me-3"></i> Overview
                                            </a>
                                        </div>
                                        <div class="col-6 mb-3">
                                            <a class="dropdown-item d-flex align-items-center" href="#">
                                                <i class="fa fa-user-md text-primary me-3"></i> Find a Practitioner
                                            </a>
                                        </div>
                                        <div class="col-6 mb-3">
                                            <a class="dropdown-item d-flex align-items-center" href="#">
                                                <i class="fa fa-building text-primary me-3"></i> Inspectorate
                                            </a>
                                        </div>
                                        <div class="col-6 mb-3">
                                            <a class="dropdown-item d-flex align-items-center" href="#">
                                                <i class="fa fa-briefcase text-primary me-3"></i> Careers
                                            </a>
                                        </div>
                                        <div class="col-12">
                                            <a class="dropdown-item d-flex align-items-center" href="#">
                                                <i class="fa fa-file-text text-primary me-3"></i> Regulation 4A Appeals
                                            </a>
                                        </div>
                                    </div>
                                </ul>
                            </div>
                            <!-- 3 Practitioners -->
                            <div class="col-lg-3 col-md-6 dropdown">
                                <div style="background:purple;height:90px;border-radius:12px;display:flex;flex-direction:column;align-items:center;justify-content:center;font-size:18px;font-weight:600;cursor:pointer;"
                                            data-bs-toggle="dropdown"
                                            aria-expanded="false">
                                    <div>For the Practitioners</div>
                                    <i class="fa fa-angle-down mt-2"></i>
                                </div>
                                <ul class="dropdown-menu shadow-lg border-0 p-4 mt-2"
                                        style="min-width:450px;border-radius:15px;">
                                    <div class="row text-start text-dark fw-normal">
                                        <div class="col-6 mb-2">
                                            <a class="dropdown-item" href="#">
                                                <i class="fa fa-graduation-cap text-primary me-2"></i> CPD Program
                                            </a>
                                        </div>
                                        <div class="col-6 mb-2">
                                            <a class="dropdown-item" href="#">
                                                <i class="fa fa-id-card text-primary me-2"></i> Renewals
                                            </a>
                                        </div>
                                        <div class="col-6">
                                            <a class="dropdown-item" href="#">
                                                <i class="fa fa-balance-scale text-primary me-2"></i> Ethics
                                            </a>
                                        </div>
                                        <div class="col-6">
                                            <a class="dropdown-item" href="#">
                                                <i class="fa fa-folder-open text-primary me-2"></i> Resources
                                            </a>
                                        </div>
                                    </div>
                                </ul>
                            </div>
                            <!-- 4 Public -->
                            <div class="col-lg-3 col-md-6 dropdown">
                                <div style="background:#e53935;height:90px;border-radius:12px;display:flex;flex-direction:column;align-items:center;justify-content:center;font-size:18px;font-weight:600;cursor:pointer;"
                                        data-bs-toggle="dropdown"
                                        aria-expanded="false">
                                    <div>For the Public</div>
                                    <i class="fa fa-angle-down mt-2"></i>
                                </div>
                                <ul class="dropdown-menu shadow-lg border-0 p-4 mt-2"
                                    style="min-width:450px;border-radius:15px;">
                                    <div class="row text-start text-dark fw-normal">
                                        <div class="col-6 mb-2">
                                            <a class="dropdown-item" href="#">
                                                <i class="fa fa-bullhorn text-primary me-2"></i> Lodge Complaint
                                            </a>
                                        </div>
                                        <div class="col-6 mb-2">
                                            <a class="dropdown-item" href="#">
                                                <i class="fa fa-newspaper-o text-primary me-2"></i> Media Release
                                            </a>
                                        </div>
                                        <div class="col-6">
                                            <a class="dropdown-item" href="#">
                                                <i class="fa fa-question-circle text-primary me-2"></i> FAQ
                                            </a>
                                        </div>
                                        <div class="col-6">
                                            <a class="dropdown-item" href="#">
                                                <i class="fa fa-phone text-primary me-2"></i> Contact Us
                                            </a>
                                        </div>
                                    </div>
                                </ul>
                            </div>
                        </div>
                    </div>
                    <!-- CAROUSEL -->
                    <div id="heroBgCarousel" class="carousel slide carousel-fade"
                            data-bs-ride="carousel"
                            data-bs-interval="4000"
                            style="position:absolute; top:0; left:0; width:100%; height:100%; z-index:1;">
                        <div class="carousel-inner" style="height:100%;">
                            <!-- SLIDE 1 -->
                            <div class="carousel-item active" style="height:100%;">
                                <div style="background-image: url('practitioner_registration/static/src/slider1.png'); background-size:cover;background-position:center;height:100%;width:100%;position:absolute;"></div>
                                <div class="container d-flex flex-column justify-content-center h-100 position-relative pt-5" style="z-index:10;">
                                    <div class="row justify-content-end">
                                        <div class="col-lg-7 text-end">
                                            <h2 style="color:#ff9800;font-size:2.5rem;font-weight:700;">
                                            Notice: Registration Guidelines
                                            </h2>
                                            <p class="lead mb-4">
                                            Complete your professional registration online.
                                            </p>
                                            <a href="/practitioner/registration"
                                                class="btn btn-light btn-lg px-5">
                                                START NOW
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <!-- SLIDE 2 -->
                            <div class="carousel-item" style="height:100%;">
                                <div style="background-image: url('practitioner_registration/static/src/slider2.png'); background-size:cover;background-position:center;height:100%;width:100%;position:absolute;"></div>
                                <div class="container d-flex flex-column justify-content-center h-100 position-relative pt-5" style="z-index:10;">
                                    <div class="row justify-content-end">
                                        <div class="col-lg-7 text-end">
                                            <h2 style="color:#ff9800;font-size:2.5rem;font-weight:700;">
                                            Notice: Registration Guidelines
                                            </h2>
                                            <p class="lead mb-4">
                                            Complete your professional registration online.
                                            </p>
                                            <a href="/practitioner/registration"
                                                class="btn btn-light btn-lg px-5">
                                                START NOW
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <!-- SLIDE 3 -->
                            <div class="carousel-item" style="height:100%;">
                                <div style="background-image: url('practitioner_registration/static/src/slider3.png'); background-size:cover;background-position:center;height:100%;width:100%;position:absolute;"></div>
                                <div class="container d-flex flex-column justify-content-center h-100 position-relative pt-5" style="z-index:10;">
                                    <div class="row justify-content-end">
                                        <div class="col-lg-7 text-end">
                                            <h2 style="color:#ff9800;font-size:2.5rem;font-weight:700;">
                                            Notice: Registration Guidelines
                                            </h2>
                                            <p class="lead mb-4">
                                            Complete your professional registration online.
                                            </p>
                                            <a href="/practitioner/registration"
                                                class="btn btn-light btn-lg px-5">
                                                START NOW
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <!-- Left Arrow -->
                        <button class="carousel-control-prev" type="button" data-bs-target="#heroBgCarousel" data-bs-slide="prev">
                            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                            <span class="visually-hidden">Previous</span>
                        </button>
                        <!-- Right Arrow -->
                        <button class="carousel-control-next" type="button" data-bs-target="#heroBgCarousel" data-bs-slide="next">
                            <span class="carousel-control-next-icon" aria-hidden="true"></span>
                            <span class="visually-hidden">Next</span>
                        </button>
                    </div>
                </section>
                <!-- INFORMATION CARDS -->
                <div class="container" style="margin-top:-40px; position:relative; z-index:10;">
                    <div class="row justify-content-center">
                        <div class="col-md-4 mb-4">
                            <div class="card shadow border-0 p-4 h-100">
                                <h5>
                                    <i class="fa fa-stethoscope text-primary me-2"></i>
                                    Scope of Professions
                                </h5>
                                <p class="text-muted small">
                                    The scope of professions is defined in terms of section 33 of the Health Professions Act.
                                </p>
                                <button class="btn btn-primary btn-sm mt-3">
                                    <a href="/mlp" class="text-white">
                                        View Scope of Professions
                                    </a>
                                </button>
                            </div>
                        </div>
                        <div class="col-md-4 mb-4">
                            <div class="card shadow border-0 p-4 h-100">
                                <h5>
                                    <i class="fa fa-book text-primary me-2"></i>
                                        CPD
                                </h5>
                                <p class="text-muted small">
                                        The CPD programme is implemented under legislative authority to ensure skills maintenance.
                                </p>
                                <button class="btn btn-primary btn-sm mt-3">
                                    View CPD Guidelines
                                </button>
                            </div>
                        </div>
                        <div class="col-md-4 mb-4">
                            <div class="card shadow border-0 p-4 h-100">
                                <h5>
                                    <i class="fa fa-balance-scale  me-2"></i>
                                    Ethics
                                </h5>
                                <p class="text-muted small">
                                    Health professionals registered with the HPCSA have rights and responsibilities.
                                </p>
                                <button class="btn btn-primary btn-sm mt-3">
                                    View Ethical Guidelines
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </t>
        <xpath expr="//div[@id='wrap']" position="after">
            <t t-if="request.params.get('registration_success')">
                <div id="registration_success_alert" class="alert alert-success alert-dismissible fade show shadow-lg border-0 d-flex flex-column align-items-center justify-content-center text-center" 
             role="alert" 
             style="position: fixed; top: 100px; right: 30px; z-index: 9999; 
                    width: 260px; min-height: 180px; border-radius: 15px; padding: 2rem; background-color: white;">
                    <div class="mb-3">
                        <i class="fa fa-check-circle text-success" style="font-size: 3rem;"/>
                    </div>
                    <div>
                        <h5 class="fw-bold mb-1" style="color: #198754;">Success!</h5>
                        <p class="small mb-0 text-muted">Your registration has been submitted successfully.</p>
                    </div>
                    <button type="button" class="btn-close p-3" data-bs-dismiss="alert" aria-label="Close" style="top: 10px; right: 10px;"></button>
                </div>
                <script type="text/javascript">
                    <!-- 1. Auto-hide the alert after 4 seconds -->
                    setTimeout(function() {
                        $('#registration_success_alert').fadeOut('slow', function() {
                            $(this).remove();
                        });
                    }, 4000);
                            <!-- 2. CLEAN URL: Remove the success parameter so refresh doesn't trigger the alert again -->
                    if (window.history.replaceState) {
                        const url = new URL(window.location.href);
                        url.searchParams.delete('registration_success');
                        window.history.replaceState({path: url.href}, '', url.href);
                    }
                </script>
            </t>
        </xpath>
    </template>
</odoo>