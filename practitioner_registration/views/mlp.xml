<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="mlp_template" name="MLP Registration">
        <t t-call="website.layout">
            <div id="wrap" class="oe_structure oe_empty">
                <section class="s_title pt48 pb48 text-white" style="background-color: #004C98 !important; border-bottom-left-radius: 50px; border-bottom-right-radius: 50px;">
                    <div class="container text-center">
                        <h1 class="display-3 fw-bold">Maintenance of Licensure Programme</h1>
                        <p class="lead">Enhancing CPD through professional competence and patient outcomes.</p>
                        <hr class="s_hr_sm w-25 mx-auto border-white"/>
                    </div>
                </section>
                <section class="s_text_block pt48 pb64 bg-100">
                    <div class="container">
                        <div class="row">
                            <div class="col-lg-8">
                                <div class="p-4 bg-white rounded shadow-sm">
                                    <p class="text-justify" style="line-height: 1.8;">
                                        The Health Professions Council of South Africa (
                                        <strong>HPCSA</strong>) implements the Continuing Professions Development (CPD) programme according to section 26 of the Health Professions Act of 1974. Following stakeholder consultation, the HPCSA is developing a system to enhance the current CPD programme, assisting health practitioners in demonstrating competence linked to patient outcomes.
                                    </p>
                                    <p class="text-justify" style="line-height: 1.8;">
                                        The
                                        <strong>MOL (Maintenance of Licensure)</strong> is supported by three volunteer boards:
                                        <em>Occupational Therapy, Medical Orthotics, Prosthetics and Arts Therapy (OCP)</em>,
                                        <em>Medical Technology (MTB)</em>, and the
                                        <em>Medical, Dental and Medical Sciences Board (MDB)</em>.
                                    </p>
                                    <div class="alert alert-info mt32 mb-0">
                                        <i class="fa fa-info-circle mr-2"/> The HPCSA will keep stakeholders updated on the progress of the development.
                                    </div>
                                </div>
                            </div>
                            <div class="col-lg-4">
                                    <div class="card border-0 shadow-sm overflow-hidden">
                                        <button type="button" 
                                                class="card-header w-100 text-white text-center border-0 p-3" 
                                                style="background-color: #004C98 !important; cursor: pointer; display: block;"
                                                data-bs-toggle="collapse" 
                                                data-bs-target="#collapseDocuments" 
                                                aria-expanded="false" 
                                                aria-controls="collapseDocuments">
                                            <h4 class="mb-0">
                                                <i class="fa fa-file-text-o mr-2"/> Important Documents
                                                <i class="fa fa-chevron-down ml-2 small"/>
                                            </h4>
                                        </button>

                                        <div id="collapseDocuments" class="collapse">
                                            <div class="card-body bg-white border-top">
                                                <ul class="list-unstyled mb-0">
                                                    <li class="mb-2">
                                                        <a href="#" class="btn btn-block text-left d-flex justify-content-between align-items-center" 
                                                        style="border: 1px solid #004C98; color: #004C98;">
                                                            <span><i class="fa fa-download mr-2"/> MOL Framework</span>
                                                            <i class="fa fa-chevron-right small text-muted"/>
                                                        </a>
                                                    </li>
                                                    <li class="mb-2">
                                                        <a href="#" class="btn btn-block text-left d-flex justify-content-between align-items-center" 
                                                        style="border: 1px solid #004C98; color: #004C98;">
                                                            <span><i class="fa fa-download mr-2"/> MOL Guidelines</span>
                                                            <i class="fa fa-chevron-right small text-muted"/>
                                                        </a>
                                                    </li>
                                                    <li>
                                                        <a href="#" class="btn btn-block text-left d-flex justify-content-between align-items-center" 
                                                        style="border: 1px solid #004C98; color: #004C98;">
                                                            <span><i class="fa fa-question-circle mr-2"/> MOL FAQs</span>
                                                            <i class="fa fa-chevron-right small text-muted"/>
                                                        </a>
                                                    </li>
                                                </ul>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>
            </div>
        </t>
    </template>
</odoo>