	<record id="digital_maintenance_of_licensure_view_form" model="ir.ui.view">
        <field name="name">crm.lead.form</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">

        	<button name="action_set_won_rainbowman" position="attributes">
        		<attribute name="string">Approve</attribute>
        	</button>

        	<xpath expr="//button[@name='%(crm.crm_lead_lost_action)d']" position="attributes">
			    <attribute name="string">Reject</attribute>
			</xpath>

        	<xpath expr="//div[contains(@class, 'oe_title')]//field[@name='name']" position="attributes">
	            <attribute name="placeholder">Licensure Name...</attribute>
	        </xpath>

            <xpath expr="//group[@name='opportunity_partner']//field[@name='partner_id']" position="attributes">
                <attribute name="string">Practitioner</attribute>
            </xpath>

        	<xpath expr="//h2[contains(@class, 'row')]" position="attributes">
        		<attribute name="invisible">1</attribute>
        	</xpath>

        	<field name="user_id" position="attributes">
        		<attribute name="invisible">1</attribute>
        	</field>

        	<field name="date_deadline" position="attributes">
        		<attribute name="invisible">1</attribute>
        	</field>

        	<xpath expr="//group[1]" position="inside">
        		<group string="Professional Details">
    				<field name="profession_category_id"/>
    				<field name="Registration_number"/>
    				<field name="board_type"/>
    			</group>

    			<group string="Practice Permissions">
    				<field name="rwpos_approval"/>
    				<field name="sessional_contract"/>
    			</group>
        	</xpath>

        	<page name='internal_notes' position="before">
                <page name="licensure_ids" string="Licensure Details">
                	<field name="licensure_ids">
                		<list editable="top">
	                		<field name="name"/>
	                		<field name="documents"/>
                		</list>
                	</field>
                </page>
            </page>

            <page name="lead" position="attributes">
            	<attribute name="string">Additional Details</attribute>
            </page>
        </field>
    </record>
</odoo>
