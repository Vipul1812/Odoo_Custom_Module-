<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="awesome_dashboard.ConfigDialog" owl="1">
        <Dialog title="'Configure Dashboard'" size="'md'">
            <div class="list-group">
                <t t-foreach="props.items" t-as="item" t-key="item.id">
                    <label class="list-group-item d-flex align-items-center cursor-pointer">
                        <CheckBox 
                            value="state.checkedIds.includes(item.id)" 
                            onChange="() => this.toggleItem(item.id)" 
                        />
                        <span class="ms-2"><t t-esc="item.name"/></span>
                    </label>
                </t>
            </div>
            <t t-set-slot="footer">
                <button class="btn btn-primary" t-on-click="onApply">Apply</button>
                <button class="btn btn-secondary" t-on-click="props.close">Cancel</button>
            </t>
        </Dialog>
    </t>
</templates>
