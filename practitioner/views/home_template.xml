<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="home_template" name="HPCSA Home Page">
        <t t-call="website.layout">
            <div id="wrap" class="hpcsa_custom_page">

                <!-- HERO SECTION -->
                <section class="position-relative text-white" style="min-height:600px; overflow:hidden;">

                    <!-- COLORED MENU BOXES -->
                    <div class="container" style="position:absolute; top:40px; left:0; right:0; z-index:20;">
                        <div class="row g-3">

                            <!-- PROFESSIONAL BOARDS -->
                            <div class="col-lg-3 col-md-6 dropdown">
                                <div class="menu-box bg-warning text-center"
                                     style="height:90px;border-radius:12px;display:flex;flex-direction:column;align-items:center;justify-content:center;font-size:18px;font-weight:600;cursor:pointer;"
                                     data-bs-toggle="dropdown">

                                    <div>Professional Boards</div>
                                    <i class="fa fa-angle-down mt-2"/>
                                </div>

                                <ul class="dropdown-menu shadow-lg border-0 p-4 mt-2"
                                    style="min-width:450px;border-radius:15px;">

                                    <li>
                                        <a class="dropdown-item" href="#">
                                            <i class="fa fa-users text-primary me-2"/> Board Overview
                                        </a>
                                    </li>

                                    <li>
                                        <a class="dropdown-item" href="#">
                                            <i class="fa fa-gavel text-primary me-2"/> Legal Framework
                                        </a>
                                    </li>

                                    <li>
                                        <a class="dropdown-item" href="#">
                                            <i class="fa fa-calendar text-primary me-2"/> Meetings
                                        </a>
                                    </li>

                                    <li>
                                        <a class="dropdown-item" href="#">
                                            <i class="fa fa-info-circle text-primary me-2"/> Guidelines
                                        </a>
                                    </li>

                                </ul>
                            </div>


                            <!-- REGISTRATION -->
                            <div class="col-lg-3 col-md-6 dropdown">
                                <div class="menu-box bg-success text-center"
                                     style="height:90px;border-radius:12px;display:flex;flex-direction:column;align-items:center;justify-content:center;font-size:18px;font-weight:600;cursor:pointer;"
                                     data-bs-toggle="dropdown">

                                    <div>Registration</div>
                                    <i class="fa fa-angle-down mt-2"/>
                                </div>

                                <ul class="dropdown-menu shadow-lg border-0 p-4 mt-2"
                                    style="min-width:550px;border-radius:15px;">

                                    <li>
                                        <a class="dropdown-item" href="#">
                                            <i class="fa fa-search-plus text-primary me-3"/> Overview
                                        </a>
                                    </li>

                                    <li>
                                        <a class="dropdown-item" href="#">
                                            <i class="fa fa-user-md text-primary me-3"/> Find a Practitioner
                                        </a>
                                    </li>

                                    <li>
                                        <a class="dropdown-item" href="#">
                                            <i class="fa fa-building text-primary me-3"/> Inspectorate
                                        </a>
                                    </li>

                                    <li>
                                        <a class="dropdown-item" href="#">
                                            <i class="fa fa-briefcase text-primary me-3"/> Careers
                                        </a>
                                    </li>

                                    <li>
                                        <a class="dropdown-item" href="#">
                                            <i class="fa fa-file-text text-primary me-3"/> Regulation 4A Appeals
                                        </a>
                                    </li>

                                </ul>
                            </div>


                            <!-- PRACTITIONERS -->
                            <div class="col-lg-3 col-md-6 dropdown">
                                <div class="menu-box text-white text-center"
                                     style="background:purple;height:90px;border-radius:12px;display:flex;flex-direction:column;align-items:center;justify-content:center;font-size:18px;font-weight:600;cursor:pointer;"
                                     data-bs-toggle="dropdown">

                                    <div>For the Practitioners</div>
                                    <i class="fa fa-angle-down mt-2"/>
                                </div>

                                <ul class="dropdown-menu shadow-lg border-0 p-4 mt-2"
                                    style="min-width:450px;border-radius:15px;">

                                    <li>
                                        <a class="dropdown-item" href="#">
                                            <i class="fa fa-graduation-cap text-primary me-2"/> CPD Program
                                        </a>
                                    </li>

                                    <li>
                                        <a class="dropdown-item" href="#">
                                            <i class="fa fa-id-card text-primary me-2"/> Renewals
                                        </a>
                                    </li>

                                    <li>
                                        <a class="dropdown-item" href="#">
                                            <i class="fa fa-balance-scale text-primary me-2"/> Ethics
                                        </a>
                                    </li>

                                    <li>
                                        <a class="dropdown-item" href="#">
                                            <i class="fa fa-folder-open text-primary me-2"/> Resources
                                        </a>
                                    </li>

                                </ul>
                            </div>


                            <!-- PUBLIC -->
                            <div class="col-lg-3 col-md-6 dropdown">
                                <div class="menu-box bg-danger text-center"
                                     style="height:90px;border-radius:12px;display:flex;flex-direction:column;align-items:center;justify-content:center;font-size:18px;font-weight:600;cursor:pointer;"
                                     data-bs-toggle="dropdown">

                                    <div>For the Public</div>
                                    <i class="fa fa-angle-down mt-2"/>
                                </div>

                                <ul class="dropdown-menu shadow-lg border-0 p-4 mt-2"
                                    style="min-width:450px;border-radius:15px;">

                                    <li>
                                        <a class="dropdown-item" href="#">
                                            <i class="fa fa-bullhorn text-primary me-2"/> Lodge Complaint
                                        </a>
                                    </li>

                                    <li>
                                        <a class="dropdown-item" href="#">
                                            <i class="fa fa-newspaper-o text-primary me-2"/> Media Release
                                        </a>
                                    </li>

                                    <li>
                                        <a class="dropdown-item" href="#">
                                            <i class="fa fa-question-circle text-primary me-2"/> FAQ
                                        </a>
                                    </li>

                                    <li>
                                        <a class="dropdown-item" href="#">
                                            <i class="fa fa-phone text-primary me-2"/> Contact Us
                                        </a>
                                    </li>

                                </ul>
                            </div>

                        </div>
                    </div>


                    <!-- HERO CAROUSEL -->
                    <div id="heroBgCarousel"
                         class="carousel slide carousel-fade"
                         data-bs-ride="carousel"
                         data-bs-interval="4000"
                         style="position:absolute;top:0;left:0;width:100%;height:100%;">

                        <div class="carousel-inner h-100">

                            <!-- SLIDE -->
                            <div class="carousel-item active h-100 position-relative">

                                <div style="background-image:url('/practitioner/static/src/img/hpcsa (1).png');
                                            background-size:cover;
                                            background-position:center;
                                            position:absolute;
                                            width:100%;
                                            height:100%;
                                            z-index:1;">
                                </div>

                                <div style="position:absolute;
                                            width:100%;
                                            height:100%;
                                            background:rgba(0,0,0,0.45);
                                            z-index:2;">
                                </div>

                                <div class="container h-100 d-flex align-items-center position-relative" style="z-index:3;">
                                    <div class="row justify-content-end w-100">
                                        <div class="col-lg-7 text-end">

                                            <h2 style="color:#ff9800;font-size:2.5rem;font-weight:700;">
                                                Notice: Registration Guidelines
                                            </h2>

                                            <p class="lead mb-4">
                                                Complete your professional registration online.
                                            </p>

                                            <a href="/practitioner/registration"
                                               class="btn btn-light btn-lg px-5">
                                                START NOW
                                            </a>

                                        </div>
                                    </div>
                                </div>

                            </div>

                        </div>

                    </div>

                </section>


                <!-- INFORMATION CARDS -->
                <div class="container" style="margin-top:-40px; position:relative; z-index:10;">
                    <div class="row justify-content-center">

                        <div class="col-md-4 mb-4">
                            <div class="card shadow border-0 p-4 h-100">
                                <h5>
                                    <i class="fa fa-stethoscope text-primary me-2"/>
                                    Scope of Professions
                                </h5>
                                <p class="text-muted small">
                                    The scope of professions is defined in terms of section 33 of the Health Professions Act.
                                </p>
                            </div>
                        </div>

                        <div class="col-md-4 mb-4">
                            <div class="card shadow border-0 p-4 h-100">
                                <h5>
                                    <i class="fa fa-book text-primary me-2"/>
                                    CPD
                                </h5>
                                <p class="text-muted small">
                                    The CPD programme ensures professionals maintain their skills.
                                </p>
                            </div>
                        </div>

                        <div class="col-md-4 mb-4">
                            <div class="card shadow border-0 p-4 h-100">
                                <h5>
                                    <i class="fa fa-balance-scale text-primary me-2"/>
                                    Ethics
                                </h5>
                                <p class="text-muted small">
                                    Health professionals registered with the HPCSA have rights and responsibilities.
                                </p>
                            </div>
                        </div>

                    </div>
                </div>

            </div>
        </t>
    </template>
</odoo>