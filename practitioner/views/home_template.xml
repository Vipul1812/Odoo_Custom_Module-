<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="home_template" name="HPCSA Home Page">
        <t t-call="website.layout">

            <div id="wrap" class="hpcsa_custom_page">

                <!-- HERO SECTION -->
                <section class="position-relative text-white"
                    style="background-image:
                    linear-gradient(rgba(0,84,166,0.7),rgba(0,84,166,0.7)),
                    url('practitioner/static/src/img/hpcsa (1).png');
                    background-size:cover;
                    background-position:center;
                    background-repeat:no-repeat;
                    min-height:520px;
                    display:flex;
                    align-items:center;">

                    <!-- COLORED MENU BOXES -->
                    <div class="container"
                         style="position:absolute; top:40px; left:0; right:0; z-index:20;">
                        <div class="row text-center text-white fw-bold g-4 justify-content-center">

                            <div class="col-lg-3 col-md-6">
                                <div style="background:#d4b116;height:90px;border-radius:12px;
                                display:flex;flex-direction:column;align-items:center;justify-content:center;
                                font-size:18px;font-weight:600;">
                                    <div>Professional Boards</div>
                                    <i class="fa fa-angle-down mt-2"></i>
                                </div>
                            </div>

                            <div class="col-lg-3 col-md-6">
                                <div style="background:#16a765;height:90px;border-radius:12px;
                                display:flex;flex-direction:column;align-items:center;justify-content:center;
                                font-size:18px;font-weight:600;">
                                    <div>Registration</div>
                                    <i class="fa fa-angle-down mt-2"></i>
                                </div>
                            </div>

                            <div class="col-lg-3 col-md-6">
                                <div style="background:#1f5fa8;height:90px;border-radius:12px;
                                display:flex;flex-direction:column;align-items:center;justify-content:center;
                                font-size:18px;font-weight:600;">
                                    <div>For the Practitioners</div>
                                    <i class="fa fa-angle-down mt-2"></i>
                                </div>
                            </div>

                            <div class="col-lg-3 col-md-6">
                                <div style="background:#e53935;height:90px;border-radius:12px;
                                display:flex;flex-direction:column;align-items:center;justify-content:center;
                                font-size:18px;font-weight:600;">
                                    <div>For the Public</div>
                                    <i class="fa fa-angle-down mt-2"></i>
                                </div>
                            </div>

                        </div>
                    </div>

                    <!-- HERO TEXT -->
                    <div class="container position-relative" style="z-index:2;">
                        <div class="row align-items-center">
                            <div class="col-lg-7 text-end">
                                <h2 style="color:#ff9800;">
                                    Notice: Registration Guidelines
                                </h2>
                                <p class="lead">
                                    Complete your professional registration online.
                                </p>
                                <a href="/practitioner/registration"
                                   class="btn btn-light btn-lg">
                                    START NOW
                                </a>
                            </div>
                        </div>
                    </div>

                </section>

                <!-- INFORMATION CARDS -->
                <div class="container"
                     style="margin-top:-80px; position:relative; z-index:10;">
                    <div class="row justify-content-center">

                        <div class="col-md-4 mb-4">
                            <div class="card shadow border-0 p-4 h-100">
                                <h5>
                                    <i class="fa fa-stethoscope text-primary me-2"></i>
                                    Scope of Professions
                                </h5>
                                <p class="text-muted small">
                                    The scope of professions is defined in terms of section 33.
                                </p>
                            </div>
                        </div>

                        <div class="col-md-4 mb-4">
                            <div class="card shadow border-0 p-4 h-100">
                                <h5>
                                    <i class="fa fa-book text-primary me-2"></i>
                                    CPD
                                </h5>
                                <p class="text-muted small">
                                    The CPD programme is implemented under legislative authority.
                                </p>
                            </div>
                        </div>

                        <div class="col-md-4 mb-4">
                            <div class="card shadow border-0 p-4 h-100">
                                <h5>
                                    <i class="fa fa-balance-scale text-primary me-2"></i>
                                    Ethics
                                </h5>
                                <p class="text-muted small">
                                    Health professionals registered with the HPCSA have rights.
                                </p>
                            </div>
                        </div>

                    </div>
                </div>

            </div>

        </t>
    </template>
</odoo>